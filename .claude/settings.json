{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "disableBypassPermissionsMode": "disable",
  "permissions": {
    "defaultMode": "plan",
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(./**/*secret*)",
      "Read(./**/*token*)",
      "Read(./**/*credential*)",
      "Bash(sudo *)",
      "Bash(git push *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(cat .env*)",
      "Bash(cat */.env*)",
      "Bash(grep * .env*)",
      "Bash(rg * .env*)",
      "Bash(gh auth token*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(git commit *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(pip install *)",
      "Bash(python -m pip install *)",
      "Bash(python main.py*)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)"
    ],
    "allow": [
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(python --version)",
      "Bash(pytest *)",
      "Bash(ruff check *)",
      "Bash(ruff format *)"
    ]
  }
}
